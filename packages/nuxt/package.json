{
  "name": "@modernice/nuxt-i18n-modules",
  "type": "module",
  "version": "0.2.0",
  "description": "\"Message modules\" extension for vue-i18n in Nuxt",
  "license": "MIT",
  "repository": "modernice/vue-i18n-modules",
  "exports": {
    ".": {
      "types": "./dist/types.d.ts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.mjs",
      "require": "./dist/middleware.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:middleware": "unbuild",
    "prepack": "nuxt-module-build && pnpm build:middleware",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build --stub && nuxi prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@modernice/vue-i18n-modules": "*",
    "@nuxtjs/i18n": "^9.0.0",
    "ufo": "^1.6.1",
    "vue-i18n": "^9.4.1"
  },
  "dependencies": {
    "@nuxt/kit": "^4.1.1",
    "consola": "^3.4.2",
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@modernice/vue-i18n-modules": "workspace:*",
    "@nuxt/devtools": "^2.6.3",
    "@nuxt/eslint-config": "^1.9.0",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.1.1",
    "@nuxt/test-utils": "^3.19.2",
    "@nuxtjs/i18n": "^10.1.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.7.2",
    "changelogen": "^0.6.2",
    "eslint": "^9.35.0",
    "jiti": "^2.5.1",
    "nuxt": "^4.1.1",
    "ufo": "^1.6.1",
    "unbuild": "^3.6.1",
    "vitest": "^3.2.4",
    "vue-i18n": "^11.1.12"
  }
}
