{
  "name": "@modernice/nuxt-i18n-modules",
  "type": "module",
  "version": "0.3.5",
  "description": "\"Message modules\" extension for vue-i18n in Nuxt",
  "license": "MIT",
  "repository": "modernice/vue-i18n-modules",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs",
      "require": "./dist/module.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.mts",
      "import": "./dist/middleware.mjs",
      "require": "./dist/middleware.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:middleware": "unbuild",
    "prepack": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\" && nuxt-module-build build && pnpm build:middleware",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build --stub && nuxi prepare playground",
    "release": "pnpm run lint && pnpm run prepack && changelogen --release && pnpm publish && git push --follow-tags",
    "lint": "eslint ."
  },
  "peerDependencies": {
    "@modernice/vue-i18n-modules": "*",
    "@nuxtjs/i18n": "^10.0.0",
    "ufo": "^1.6.1",
    "vue-i18n": "^11.3.2"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.2",
    "consola": "^3.4.2",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@modernice/vue-i18n-modules": "workspace:*",
    "@nuxt/devtools": "^3.1.1",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.2",
    "@nuxt/test-utils": "^4.0.2",
    "@nuxtjs/i18n": "^10.2.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.7.2",
    "changelogen": "^0.6.2",
    "eslint": "^10.2.1",
    "jiti": "^2.6.1",
    "nuxt": "^4.4.2",
    "ufo": "^1.6.3",
    "unbuild": "^3.6.1",
    "vitest": "^4.1.5",
    "vue-i18n": "^11.3.2"
  }
}
